# ============================================================
# Environment Variables Template - Insurance ML Pipeline
# Version: 4.2.0
# ============================================================
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the values in .env with your actual configuration
# 3. Never commit .env to version control
# 4. Keep .env.example updated with new variables (without values)
# ============================================================

# ------------------------------------------------------------
# Environment Configuration
# ------------------------------------------------------------
# Options: development, staging, production
ENVIRONMENT=development

# ------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Path to log file (relative to project root)
LOG_FILE=logs/app.log

# ------------------------------------------------------------
# Data Paths
# ------------------------------------------------------------
# Path to raw data CSV file
DATA_PATH=data/raw/insurance.csv
# Directory for processed data
PROCESSED_DATA_PATH=data/processed/
# Directory for saved models
MODEL_PATH=models/

# ------------------------------------------------------------
# Model Configuration
# ------------------------------------------------------------
# Random seed for reproducibility (any integer)
RANDOM_STATE=42
# Number of cross-validation folds
CV_FOLDS=5
# Test set size (0.0 to 1.0)
TEST_SIZE=0.2
# Validation set size (0.0 to 1.0)
VALIDATION_SIZE=0.2

# ------------------------------------------------------------
# MLflow Tracking
# ------------------------------------------------------------
# MLflow tracking URI (local path or remote server)
# Examples:
#   Local: ./mlruns
#   Remote: http://localhost:5000
#   Databricks: databricks://profile:workspace
MLFLOW_TRACKING_URI=./mlruns
# Experiment name for MLflow
MLFLOW_EXPERIMENT_NAME=insurance_prediction
# Model registry name
MLFLOW_REGISTRY_MODEL_NAME=insurance_predictor

# ------------------------------------------------------------
# GPU Configuration
# ------------------------------------------------------------
# Enable GPU acceleration (true/false or 1/0)
# Requires CUDA-enabled GPU and proper drivers
USE_GPU=false
# GPU device ID (0 for first GPU, 1 for second, etc.)
GPU_DEVICE_ID=0
# GPU memory limit in MB (for RTX 3050 4GB, use ~3500)
GPU_MEMORY_LIMIT_MB=3500

# ------------------------------------------------------------
# Optuna Hyperparameter Optimization
# ------------------------------------------------------------
# Enable Optuna optimization (true/false)
OPTUNA_ENABLED=true
# Number of optimization trials
OPTUNA_N_TRIALS=50
# Timeout in seconds (3600 = 1 hour)
OPTUNA_TIMEOUT=3600
# Number of parallel jobs (set to 1 for GPU to avoid OOM)
OPTUNA_N_JOBS=1
# Study name for Optuna
OPTUNA_STUDY_NAME=insurance_optimization
# Database URL for Optuna storage (must match actual DB location)
OPTUNA_STORAGE=sqlite:///models/optuna_studies.db

# ------------------------------------------------------------
# Training Configuration
# ------------------------------------------------------------
# Enable early stopping during training
EARLY_STOPPING_ENABLED=true
# Patience for early stopping (epochs without improvement)
EARLY_STOPPING_PATIENCE=20
# Enable checkpoint saving
CHECKPOINT_ENABLED=true

# ------------------------------------------------------------
# API Configuration (FastAPI)
# ------------------------------------------------------------
# API server host
API_HOST=127.0.0.1
# API server port
API_PORT=8000
# Number of worker processes
# FIX [HIGH]: Default changed from 4 → 1.
#   On GPU inference (RTX 3050 4GB), each uvicorn worker loads the full model
#   stack independently. 4 workers × ~1 GB model VRAM = OOM at startup.
#   Keep at 1 for any machine where models are loaded into GPU memory.
#   Set to >1 only for CPU-only deployments with sufficient RAM.
API_WORKERS=1
# Enable auto-reload on code changes (development only)
API_RELOAD=false
# Bearer token for API authentication (leave blank to disable)
API_KEY=e6f58360e87a9dd93ff142442228960b8512935fce5fa5dbaea5b1b153aa894d
# Full URL the Streamlit frontend uses to reach the API
API_URL=http://127.0.0.1:8000
# HTTP timeout in seconds for API health checks and requests
API_TIMEOUT=10
HEALTH_TIMEOUT=5
MAX_RETRIES=2

# ------------------------------------------------------------
# Streamlit Configuration
# ------------------------------------------------------------
# Streamlit app host
STREAMLIT_HOST=127.0.0.1
# Streamlit app port
STREAMLIT_PORT=8501

# ------------------------------------------------------------
# Monitoring & Performance
# ------------------------------------------------------------
# Enable data drift detection
ENABLE_DRIFT_DETECTION=true
# Path to prediction logs CSV
PREDICTION_LOG=logs/predictions.csv
# Path to metrics log JSON
METRICS_LOG=logs/metrics.json
# Track inference time for predictions
TRACK_INFERENCE_TIME=true
# Track memory usage during training
TRACK_MEMORY_USAGE=true

# ------------------------------------------------------------
# Prediction Bounds & Confidence Intervals
# ------------------------------------------------------------
# FIX [CRITICAL]: These four variables were present in .env.docker but missing
# from this template. Local runs would silently fall back to hardcoded defaults
# while Docker used these explicit values, causing divergent behaviour between
# environments. Consumed by: api/routes.py, app/streamlit_app.py, api/main.py.
#
# Minimum allowed prediction value (hard floor, USD)
PREDICTION_MIN=100
# Maximum allowed prediction value (hard ceiling, USD)
PREDICTION_MAX=500000
# Confidence level for prediction intervals (0.0–1.0)
CI_CONFIDENCE_LEVEL=0.90
# Enable model warm-up on API startup
WARMUP_ENABLED=true

# ------------------------------------------------------------
# Database Configuration (Optional - Production)
# ------------------------------------------------------------
# PostgreSQL/MySQL connection string
# Format: postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://user:password@localhost:5432/ml_db
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10

# ------------------------------------------------------------
# Cloud Storage (Optional - AWS S3)
# ------------------------------------------------------------
# AWS credentials for S3 model storage
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=ml-models-bucket
# S3_MODEL_PREFIX=models/insurance/

# ------------------------------------------------------------
# Azure ML (Optional - Azure Integration)
# ------------------------------------------------------------
# Azure ML workspace credentials
# AZURE_SUBSCRIPTION_ID=your_subscription_id
# AZURE_RESOURCE_GROUP=your_resource_group
# AZURE_WORKSPACE_NAME=your_workspace_name

# ------------------------------------------------------------
# Model Serving (Optional - Production Deployment)
# ------------------------------------------------------------
# Model server endpoint URL
# MODEL_SERVER_URL=http://localhost:8080/predict
# Model version to use (staging/production)
# MODEL_VERSION=production
# Batch size for inference
# BATCH_SIZE=32

# ------------------------------------------------------------
# Notifications (Optional - Alerts & Monitoring)
# ------------------------------------------------------------
# Slack webhook for training alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notifications (SMTP)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=alerts@yourcompany.com
# EMAIL_TO=team@yourcompany.com
# EMAIL_PASSWORD=your_app_password

# ------------------------------------------------------------
# Additional Notes
# ------------------------------------------------------------
# RTX 3050 4GB Optimization:
# - Keep OPTUNA_N_JOBS=1 to avoid GPU OOM
# - Use GPU_MEMORY_LIMIT_MB=3500 to reserve system memory
# - Keep API_WORKERS=1 for GPU inference to prevent VRAM OOM
# - Monitor memory with: python scripts/monitor_gpu.py
#
# Training Commands:
# - GPU training: python scripts/train_model.py --use-gpu
# - CPU training: python scripts/train_model.py
# - Single model: python scripts/train_model.py --model xgboost
# - No optimization: python scripts/train_model.py --no-optuna
# ============================================================
