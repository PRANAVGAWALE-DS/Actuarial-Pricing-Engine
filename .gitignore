# =====================================================
# Data Files
# =====================================================
# Raw data
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
data/raw/*.parquet
data/raw/*.feather
data/raw/*.pkl

# Processed data
data/processed/*.csv
data/processed/*.pkl
data/processed/*.parquet
data/processed/*.feather

# External data
data/external/

# Interim data
data/interim/

# Sample data — used by CI regression gate (scripts/ci_model_gate.py).
# data/sample/ itself is ignored so future large files don't slip in, but
# the two synthetic CSVs required by ci_model_gate.py are explicitly
# un-ignored.  These files contain no real customer data (public UCI
# insurance dataset splits, seed=42).
data/sample/
# M3 FIX: un-ignore the specific CI gate sample files.
# Without these the CI model regression gate raises FileNotFoundError and
# the Stage 4 gate always fails on a clean checkout.
!data/sample/train_sample.csv
!data/sample/test_sample.csv

# Keep data directory structure
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/interim/.gitkeep
!data/sample/.gitkeep

# Large files
*.hdf5
*.h5
*.hdf
*.sqlite
*.db

