# SageMath parsed files
*.sage.py

# Environments
# FIX [D3-P1]: Replaced narrow patterns (.env, .env.local, .env.*.local, *.env)
# with a single .env.* glob that covers all variants including .env.docker.
# The old patterns did not match .env.docker (which ends in .docker, not .env),
# creating a gap where a developer could accidentally commit real secrets from
# .env.docker (MLFLOW credentials, AWS keys, API_KEY) to git history.
# !.env.example is preserved — that file is safe to track (no real secrets).
.env.*
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# =====================================================
# Machine Learning Specific
# =====================================================
# Models
models/*.pkl
models/*.joblib
# FIX [LOW]: duplicate models/*.joblib entry removed (was listed twice).
models/*.h5
models/*.pth
models/*.pt
models/*.ckpt
models/*.pb
models/*.onnx
models/*.tflite
models/*.keras
models/*.json
# Exception: operational JSON files that the pipeline reads at inference time —
# these are versioned state, not generated outputs
!models/bias_correction.json
!models/drift_baseline.json
!models/pipeline_metadata.json
!models/test_indices.json
models/*.stale
models/*.ubj
models/*.db
models/*.txt

*.model

# Keep model directory structure but ignore contents
!models/.gitkeep
!models/README.md

# Preprocessors & Transformers
preprocessor*.joblib
scaler*.joblib
encoder*.joblib
imputer*.joblib
transformer*.joblib

