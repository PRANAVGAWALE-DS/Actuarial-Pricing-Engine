!.gitkeep
!.gitattributes
!.editorconfig
!.pre-commit-config.yaml
!pyproject.toml
!requirements.txt
!README.md
!LICENSE
!CHANGELOG.md
!.env.example

# =====================================================
# Notes
# =====================================================
# To track a file that's ignored:
#   git add -f <file>
#
# To see what's being ignored:
#   git status --ignored
#
# To check if a file is ignored:
#   git check-ignore -v <file>
# =====================================================

