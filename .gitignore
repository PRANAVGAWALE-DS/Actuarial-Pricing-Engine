# =====================================================
# Cloud & Deployment
# =====================================================
# FIX [LOW]: .dockerignore removed from this block.
# .dockerignore is a tracked project infrastructure file (like .gitignore
# itself). It was incorrectly ignored, meaning contributors who ran
# `git add -A` after a fresh checkout could not add it.
# Run: git rm --cached .dockerignore  (if it was previously tracked as ignored)
docker-compose.override.yml
# H2 FIX: MLflow basic-auth credentials — never commit real passwords.
# Copy docker/mlflow_basic_auth.ini.example → docker/mlflow_basic_auth.ini and set values.
docker/mlflow_basic_auth.ini

